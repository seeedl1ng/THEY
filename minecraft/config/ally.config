# Configuration file

general {
    # If true, players are never considered allies. [default: true]
    B:ignorePlayers=true

    # Combine any of: deflect, ignore, pass. NOTE: 'deflect' and 'ignore' are mutually exclusive; if both present, 'deflect' wins. 'pass' can combine with either. [default: [deflect]]
    S:modes <
        deflect
     >

    # If true, during a group war each rallied team will target ANY member of the opposing team (including passive mobs) within radius. [default: false]
    B:purgeEnabled=false

    # How long the group stays 'angry' (reserved for future use). [range: 40 ~ 24000, default: 600]
    I:warAngerTicks=600

    # If true, when a member of group A hurts a member of group B, nearby members of BOTH groups rally. [default: true]
    B:warEnabled=true

    # Rally radius (in blocks). [range: 4.0 ~ 128.0, default: 24.0]
    S:warRadius=24.0
}


